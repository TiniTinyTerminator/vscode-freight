{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/../.."
      ],
      "outFiles": [],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**",
        "!${env:HOME}/.vscode-server/**"
      ],
      "skipFiles": [
        "<node_internals>/**",
        "${env:HOME}/.vscode-server/**"
      ],
      "preLaunchTask": "bun: package"
    }
  ]
}
